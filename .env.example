# Skopiuj ten plik do .env i uzupełnij klucze, jeśli chcesz używać modeli chmurowych

# Klucz do darmowego API Groq (https://console.groq.com/keys)
GROQ_API_KEY="your-api-key-here"

# Klucz do darmowego Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY="your-api-key-here"

# Klucz do API DeepSeek (https://platform.deepseek.com/)
DEEPSEEK_API_KEY="your-api-key-here"
